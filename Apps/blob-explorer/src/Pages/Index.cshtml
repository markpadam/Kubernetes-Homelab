@page
@model IndexModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Blob Explorer</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-light">
<div class="container mt-4" style="max-width:800px">

    <div class="mb-4">
        <h1 class="mb-0">Blob Explorer</h1>
        <p class="text-muted">
            Storage account: <code>@Model.StorageAccount</code> &nbsp;·&nbsp;
            Container: <code>uploads</code>
        </p>
    </div>

    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <h5 class="card-title">Upload a file</h5>
            <form method="post" enctype="multipart/form-data" asp-page-handler="Upload">
                <div class="input-group">
                    <input type="file" name="file" class="form-control" required />
                    <button type="submit" class="btn btn-primary">Upload</button>
                </div>
            </form>
        </div>
    </div>

    <h5>Blobs <span class="badge bg-secondary">@Model.Blobs.Count</span></h5>

    @if (Model.Blobs.Count == 0)
    {
        <div class="text-muted fst-italic">No blobs yet — upload a file above.</div>
    }
    else
    {
        <table class="table table-striped table-bordered bg-white shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Size</th>
                    <th>Last Modified</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var blob in Model.Blobs)
                {
                    <tr>
                        <td>@blob.Name</td>
                        <td>@((blob.Properties.ContentLength ?? 0) / 1024) KB</td>
                        <td>@blob.Properties.LastModified?.ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="text-end">
                            <a href="?handler=Download&blobName=@Uri.EscapeDataString(blob.Name)"
                               class="btn btn-sm btn-outline-secondary">Download</a>
                            <form method="post" asp-page-handler="Delete" class="d-inline">
                                <input type="hidden" name="blobName" value="@blob.Name" />
                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('Delete @blob.Name?')">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

</div>
</body>
</html>
